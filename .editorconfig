# Editor-agnostic baseline so indentation, line endings, and final-newline
# behaviour match between nvim, vscode, jetbrains, and anything else.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# make and just require tab-indented recipe bodies; space-indent would break
# execution. Covers both the lowercase (just convention) and capitalised form.
[{Makefile,justfile,Justfile}]
indent_style = tab

# Two trailing spaces on a markdown line mean "hard break"; keep them.
[*.md]
trim_trailing_whitespace = false
